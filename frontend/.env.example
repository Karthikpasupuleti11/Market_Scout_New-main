VITE_SENTRY_DSN=your-sentry-dsn-here
# Keep 0 in production — tracing slows the UI; errors are still captured
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_CLARITY_PROJECT_ID=your-clarity-project-id-here
VITE_FORMSPREE_ENDPOINT=your-formspree-id-here

# Backend API (dev: optional — defaults to http://localhost:8000)
# VITE_API_URL=http://localhost:8000

# Vercel (recommended): same-origin proxy — no CORS, works for all *.vercel.app URLs:
# VITE_API_URL=/api

# Or call API directly (backend must allow your origin via CORS_ORIGINS):
# VITE_API_URL=https://api.market-scout.me