# Copy to `.env` on the VM (never commit real `.env` to git).
# File path on server: ~/Market_Scout_New-main/.env

# ── API keys (required) ─────────────────────────────────────────
NVIDIA_API_KEYS=your-key-here
TAVILY_API_KEY=your-key-here

# ── Sentry (backend + Celery worker) ────────────────────────────
# DSN = report crashes only. Keep all sample rates at 0 for fast pipeline (~1–3 min).
SENTRY_DSN_BACKEND=https://your-key@your-org.ingest.sentry.io/your-project
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PIPELINE_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0

# Do NOT use 1.0 for any SENTRY_*_SAMPLE_RATE in production (slows runs to 10+ min).

# ── Optional ──────────────────────────────────────────────────────
# SENTRY_ENVIRONMENT=production
# OTEL_ENABLED=false
