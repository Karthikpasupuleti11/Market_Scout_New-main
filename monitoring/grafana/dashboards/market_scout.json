{
    "annotations": {"list": []},
    "description": "Market Intelligence Scout — API, pipelines, LLM, and infrastructure monitoring.",
    "editable": true,
    "graphTooltip": 1,
    "fiscalYearStartMonth": 0,
    "panels": [

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 100, "title": "System Overview", "type": "row"},

        {"id": 1, "title": "API Requests", "description": "User-facing API calls (excludes /metrics scrapes).", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 0, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(api_requests_total{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#6366f1"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 2, "title": "Active Pipelines", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 4, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "clamp_min(last_over_time(sum(active_pipelines{job=\"market-scout\", instance=\"app:8000\"})[5m:]), 0)", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#3b82f6"}, {"value": 3, "color": "#f59e0b"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 3, "title": "Completed", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 8, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(pipeline_runs_total{job=\"market-scout\", instance=\"app:8000\", status=\"completed\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#10b981"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 4, "title": "Errors", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 12, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(pipeline_runs_total{job=\"market-scout\", instance=\"app:8000\", status=\"error\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#ef4444"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 5, "title": "CPU Usage", "type": "gauge", "gridPos": {"h": 5, "w": 4, "x": 16, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(max(app_cpu_percent{job=\"market-scout\", instance=\"app:8000\"})[5m:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "min": 0, "max": 100, "noValue": "0", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#10b981"}, {"value": 50, "color": "#f59e0b"}, {"value": 80, "color": "#ef4444"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}},

        {"id": 6, "title": "Memory", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 20, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(app_resident_memory_bytes{job=\"market-scout\", instance=\"app:8000\"})[5m:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"unit": "bytes", "noValue": "0", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 104857600, "color": "#6366f1"}, {"value": 524288000, "color": "#f59e0b"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6}, "id": 101, "title": "API Traffic", "type": "row"},

        {"id": 10, "title": "Request Rate", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (endpoint) (rate(api_requests_total{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"}[2m]))", "legendFormat": "{{endpoint}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"id": 11, "title": "Response Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (endpoint) (rate(api_request_duration_seconds_sum{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"}[2m])) / sum by (endpoint) (rate(api_request_duration_seconds_count{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"}[2m]))", "legendFormat": "{{endpoint}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"id": 12, "title": "Status Codes", "type": "piechart", "gridPos": {"h": 8, "w": 6, "x": 0, "y": 15},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (status) (api_requests_total{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"})", "legendFormat": "{{status}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": [{"matcher": {"id": "byRegexp", "options": "200"}, "properties": [{"id": "color", "value": {"fixedColor": "#10b981", "mode": "fixed"}}]}, {"matcher": {"id": "byRegexp", "options": "4.."}, "properties": [{"id": "color", "value": {"fixedColor": "#f59e0b", "mode": "fixed"}}]}, {"matcher": {"id": "byRegexp", "options": "5.."}, "properties": [{"id": "color", "value": {"fixedColor": "#ef4444", "mode": "fixed"}}]}]},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}, "pieType": "donut"}},

        {"id": 13, "title": "Top Endpoints", "type": "bargauge", "gridPos": {"h": 8, "w": 9, "x": 6, "y": 15},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "topk(8, sum by (endpoint) (api_requests_total{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"}))", "legendFormat": "{{endpoint}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 12}},

        {"id": 14, "title": "Total API Requests", "description": "Cumulative HTTP traffic over time.", "type": "timeseries", "gridPos": {"h": 8, "w": 9, "x": 15, "y": 15},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(api_requests_total{job=\"market-scout\", instance=\"app:8000\", endpoint!~\"/metrics/?\"})", "legendFormat": "Total", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"decimals": 0, "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 18, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "fixed", "fixedColor": "#6366f1"}}},
            "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}, "id": 102, "title": "Pipeline Intelligence", "type": "row"},

        {"id": 50, "title": "Features Verified", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 0, "y": 24},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(features_verified_total{job=\"market-scout\", instance=\"app:8000\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#8b5cf6"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 51, "title": "Sources Analysed", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 4, "y": 24},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(sources_analysed_per_run_sum{job=\"market-scout\", instance=\"app:8000\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#06b6d4"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 52, "title": "Features Extracted", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 8, "y": 24},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(features_extracted_total{job=\"market-scout\", instance=\"app:8000\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#f59e0b"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 53, "title": "Avg Confidence", "type": "gauge", "gridPos": {"h": 5, "w": 4, "x": 12, "y": 24},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time((sum(feature_confidence_score_sum{job=\"market-scout\", instance=\"app:8000\"}) / clamp_min(sum(feature_confidence_score_count{job=\"market-scout\", instance=\"app:8000\"}), 1))[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 0, "min": 0, "max": 1, "noValue": "0", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#ef4444"}, {"value": 0.5, "color": "#f59e0b"}, {"value": 0.7, "color": "#10b981"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}},

        {"id": 54, "title": "Features by Category", "type": "bargauge", "gridPos": {"h": 5, "w": 8, "x": 16, "y": 24},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (category) (features_extracted_total{job=\"market-scout\", instance=\"app:8000\"})", "legendFormat": "{{category}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 12}},

        {"id": 20, "title": "Pipeline Runs", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 29},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [
                {"expr": "sum(pipeline_runs_total{job=\"market-scout\", instance=\"app:8000\", status=\"completed\"})", "legendFormat": "Completed", "refId": "A", "interval": "30s"},
                {"expr": "sum(pipeline_runs_total{job=\"market-scout\", instance=\"app:8000\", status=\"error\"})", "legendFormat": "Errors", "refId": "B", "interval": "30s"}
            ],
            "fieldConfig": {"defaults": {"decimals": 0, "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": [{"matcher": {"id": "byName", "options": "Completed"}, "properties": [{"id": "color", "value": {"fixedColor": "#10b981", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Errors"}, "properties": [{"id": "color", "value": {"fixedColor": "#ef4444", "mode": "fixed"}}]}]},
            "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"id": 56, "title": "Node Duration (p95)", "type": "bargauge", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 29},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "histogram_quantile(0.95, sum by (le, node_name) (rate(node_latency_seconds_bucket{job=\"market-scout\", instance=\"app:8000\"}[5m])))", "legendFormat": "{{node_name}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}, "min": 0}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 12}},

        {"id": 55, "title": "Verified Features by Company", "type": "bargauge", "gridPos": {"h": 7, "w": 24, "x": 0, "y": 37},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (company) (features_verified_total{job=\"market-scout\", instance=\"app:8000\"})", "legendFormat": "{{company}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 12}},

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 44}, "id": 104, "title": "LLM, Cache & Scraping", "type": "row"},

        {"id": 60, "title": "LLM Tokens", "type": "stat", "gridPos": {"h": 5, "w": 5, "x": 0, "y": 45},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(llm_tokens_total{job=\"market-scout\", instance=\"app:8000\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1000, "color": "#8b5cf6"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 61, "title": "LLM Calls", "type": "stat", "gridPos": {"h": 5, "w": 5, "x": 5, "y": 45},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(llm_calls_total{job=\"market-scout\", instance=\"app:8000\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#6366f1"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 62, "title": "Cache Hit Rate", "type": "gauge", "gridPos": {"h": 5, "w": 5, "x": 10, "y": 45},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(cache_operations_total{job=\"market-scout\", instance=\"app:8000\", operation=\"get\", status=\"hit\"}) / clamp_min(sum(cache_operations_total{job=\"market-scout\", instance=\"app:8000\", operation=\"get\"}), 1)", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 0, "min": 0, "max": 1, "noValue": "0", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#ef4444"}, {"value": 0.3, "color": "#f59e0b"}, {"value": 0.6, "color": "#10b981"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}},

        {"id": 63, "title": "Scraper Success", "type": "gauge", "gridPos": {"h": 5, "w": 5, "x": 15, "y": 45},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(scraper_attempts_total{job=\"market-scout\", instance=\"app:8000\", status=\"success\"}) / clamp_min(sum(scraper_attempts_total{job=\"market-scout\", instance=\"app:8000\"}), 1)", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 0, "min": 0, "max": 1, "noValue": "0", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#ef4444"}, {"value": 0.5, "color": "#f59e0b"}, {"value": 0.75, "color": "#10b981"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}},

        {"id": 64, "title": "URLs Discarded", "type": "stat", "gridPos": {"h": 5, "w": 4, "x": 20, "y": 45},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "last_over_time(sum(urls_discarded_total{job=\"market-scout\", instance=\"app:8000\"})[6h:])", "refId": "A", "interval": "30s"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "noValue": "0", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#f59e0b"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}},

        {"id": 65, "title": "LLM Tokens by Agent", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 50},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (agent_name) (rate(llm_tokens_total{job=\"market-scout\", instance=\"app:8000\"}[5m]))", "legendFormat": "{{agent_name}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"id": 66, "title": "Scraper Attempts by Strategy", "type": "bargauge", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 50},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (strategy, status) (scraper_attempts_total{job=\"market-scout\", instance=\"app:8000\"})", "legendFormat": "{{strategy}} ({{status}})", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 12}},

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 58}, "id": 103, "title": "Infrastructure", "type": "row"},

        {"id": 30, "title": "Services", "type": "stat", "gridPos": {"h": 8, "w": 6, "x": 0, "y": 59},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "up{instance=~\"app:8000|flower:5555\"}", "legendFormat": "{{job}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}], "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#ef4444"}, {"value": 1, "color": "#10b981"}]}}},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}},

        {"id": 31, "title": "CPU Over Time", "type": "timeseries", "gridPos": {"h": 8, "w": 6, "x": 6, "y": 59},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [
                {"expr": "max(app_cpu_percent{job=\"market-scout\", instance=\"app:8000\"})", "legendFormat": "Backend", "refId": "A", "interval": "30s"},
                {"expr": "sum(rate(process_cpu_seconds_total{job=\"flower\", instance=\"flower:5555\"}[1m])) * 100", "legendFormat": "Flower", "refId": "B"}
            ],
            "fieldConfig": {"defaults": {"unit": "percent", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"id": 32, "title": "Memory Over Time", "type": "timeseries", "gridPos": {"h": 8, "w": 6, "x": 12, "y": 59},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [
                {"expr": "sum(app_resident_memory_bytes{job=\"market-scout\", instance=\"app:8000\"})", "legendFormat": "Backend", "refId": "A", "interval": "30s"},
                {"expr": "sum(process_resident_memory_bytes{job=\"flower\", instance=\"flower:5555\"})", "legendFormat": "Flower", "refId": "B"}
            ],
            "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}},

        {"id": 35, "title": "Python GC", "type": "timeseries", "gridPos": {"h": 8, "w": 6, "x": 18, "y": 59},
