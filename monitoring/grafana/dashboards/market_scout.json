{
    "annotations": {"list": []},
    "description": "Market Intelligence Scout Monitoring",
    "editable": true,
    "graphTooltip": 1,
    "panels": [

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 100, "title": "System Overview", "type": "row"},

        {
            "id": 1, "title": "API Requests", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(api_requests_total)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#6366f1"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 2, "title": "Active Pipelines", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(active_pipelines)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#3b82f6"}, {"value": 3, "color": "#f59e0b"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 3, "title": "Completed", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(pipeline_runs_total{status=\"completed\"}) or vector(0)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#10b981"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 4, "title": "Errors", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(pipeline_runs_total{status=\"error\"}) or vector(0)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#ef4444"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 5, "title": "CPU Usage", "type": "gauge",
            "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "rate(process_cpu_seconds_total{job=\"market-scout\"}[1m]) * 100", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#10b981"}, {"value": 50, "color": "#f59e0b"}, {"value": 80, "color": "#ef4444"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}
        },
        {
            "id": 6, "title": "Memory", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "process_resident_memory_bytes{job=\"market-scout\"}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 104857600, "color": "#6366f1"}, {"value": 524288000, "color": "#f59e0b"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "id": 101, "title": "API Traffic", "type": "row"},

        {
            "id": 10, "title": "Request Rate", "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (endpoint) (rate(api_requests_total[2m]))", "legendFormat": "{{endpoint}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 11, "title": "Response Time", "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "rate(api_request_duration_seconds_sum[2m]) / rate(api_request_duration_seconds_count[2m])", "legendFormat": "{{endpoint}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 12, "title": "Status Codes", "type": "piechart",
            "gridPos": {"h": 7, "w": 6, "x": 0, "y": 14},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (status) (api_requests_total)", "legendFormat": "{{status}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": [{"matcher": {"id": "byRegexp", "options": "200"}, "properties": [{"id": "color", "value": {"fixedColor": "#10b981", "mode": "fixed"}}]}, {"matcher": {"id": "byRegexp", "options": "4.."}, "properties": [{"id": "color", "value": {"fixedColor": "#f59e0b", "mode": "fixed"}}]}, {"matcher": {"id": "byRegexp", "options": "5.."}, "properties": [{"id": "color", "value": {"fixedColor": "#ef4444", "mode": "fixed"}}]}]},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}, "pieType": "donut"}
        },
        {
            "id": 13, "title": "Top Endpoints", "type": "bargauge",
            "gridPos": {"h": 7, "w": 10, "x": 6, "y": 14},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "topk(8, sum by (endpoint) (api_requests_total))", "legendFormat": "{{endpoint}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 10}
        },
        {
            "id": 14, "title": "Cumulative Requests", "type": "timeseries",
            "gridPos": {"h": 7, "w": 8, "x": 16, "y": 14},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(api_requests_total)", "legendFormat": "Total", "refId": "A"}],
            "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "fixed", "fixedColor": "#6366f1"}}, "overrides": []},
            "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "hidden"}}
        },

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21}, "id": 102, "title": "Pipeline Intelligence", "type": "row"},

        {
            "id": 50, "title": "Features Verified", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 0, "y": 22},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(features_verified_total) or vector(0)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#8b5cf6"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 51, "title": "Sources Analysed", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 4, "y": 22},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sources_analysed_per_run_sum or vector(0)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#06b6d4"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 52, "title": "Features Extracted", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 8, "y": 22},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum(features_extracted_total) or vector(0)", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#1e293b"}, {"value": 1, "color": "#f59e0b"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
        },
        {
            "id": 53, "title": "Avg Confidence", "type": "gauge",
            "gridPos": {"h": 4, "w": 4, "x": 12, "y": 22},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "(sum(feature_confidence_score_sum) / sum(feature_confidence_score_count)) or vector(0)", "legendFormat": "", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 0, "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#ef4444"}, {"value": 0.5, "color": "#f59e0b"}, {"value": 0.7, "color": "#10b981"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}
        },
        {
            "id": 54, "title": "Features by Category", "type": "bargauge",
            "gridPos": {"h": 4, "w": 8, "x": 16, "y": 22},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (category) (features_extracted_total)", "legendFormat": "{{category}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 10}
        },
        {
            "id": 20, "title": "Pipeline Runs", "type": "timeseries",
            "gridPos": {"h": 7, "w": 12, "x": 0, "y": 26},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "increase(pipeline_runs_total{status=\"completed\"}[5m])", "legendFormat": "Completed", "refId": "A"}, {"expr": "increase(pipeline_runs_total{status=\"error\"}[5m])", "legendFormat": "Error", "refId": "B"}],
            "fieldConfig": {"defaults": {"custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "stacking": {"mode": "normal", "group": "A"}, "showPoints": "never", "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": [{"matcher": {"id": "byName", "options": "Completed"}, "properties": [{"id": "color", "value": {"fixedColor": "#10b981", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Error"}, "properties": [{"id": "color", "value": {"fixedColor": "#ef4444", "mode": "fixed"}}]}]},
            "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 55, "title": "Verified Features by Company", "type": "bargauge",
            "gridPos": {"h": 7, "w": 12, "x": 12, "y": 26},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "sum by (company) (features_verified_total)", "legendFormat": "{{company}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "min": 0}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 10}
        },

        {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33}, "id": 103, "title": "Infrastructure", "type": "row"},

        {
            "id": 30, "title": "Services", "type": "stat",
            "gridPos": {"h": 4, "w": 4, "x": 0, "y": 34},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "up", "legendFormat": "{{job}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}], "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "#ef4444"}, {"value": 1, "color": "#10b981"}]}}, "overrides": []},
            "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}
        },
        {
            "id": 31, "title": "CPU Over Time", "type": "timeseries",
            "gridPos": {"h": 7, "w": 10, "x": 4, "y": 34},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "rate(process_cpu_seconds_total{job=\"market-scout\"}[1m]) * 100", "legendFormat": "Backend", "refId": "A"}, {"expr": "rate(process_cpu_seconds_total{job=\"flower\"}[1m]) * 100", "legendFormat": "Flower", "refId": "B"}],
            "fieldConfig": {"defaults": {"unit": "percent", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 32, "title": "Memory Over Time", "type": "timeseries",
            "gridPos": {"h": 7, "w": 10, "x": 14, "y": 34},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "process_resident_memory_bytes{job=\"market-scout\"}", "legendFormat": "Backend", "refId": "A"}, {"expr": "process_resident_memory_bytes{job=\"flower\"}", "legendFormat": "Flower", "refId": "B"}],
            "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 33, "title": "Scrape Duration", "type": "timeseries",
            "gridPos": {"h": 7, "w": 8, "x": 0, "y": 41},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "scrape_duration_seconds", "legendFormat": "{{job}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 34, "title": "Metrics Scraped", "type": "timeseries",
            "gridPos": {"h": 7, "w": 8, "x": 8, "y": 41},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "scrape_samples_scraped", "legendFormat": "{{job}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        },
        {
            "id": 35, "title": "Python GC", "type": "timeseries",
            "gridPos": {"h": 7, "w": 8, "x": 16, "y": 41},
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "targets": [{"expr": "rate(python_gc_collections_total{job=\"market-scout\"}[2m])", "legendFormat": "Gen {{generation}}", "refId": "A"}],
            "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "axisSoftMin": 0}, "color": {"mode": "palette-classic"}}, "overrides": []},
            "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}
        }
    ],
    "refresh": "10s",
    "schemaVersion": 39,
    "tags": ["market-scout"],
    "templating": {"list": []},
    "time": {"from": "now-6h", "to": "now"},
